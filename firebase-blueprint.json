{
  "entities": {
    "Service": {
      "title": "Service",
      "description": "A service offered by the salon",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the service" },
        "price": { "type": "number", "description": "Sales price" },
        "cost": { "type": "number", "description": "Cost price" }
      },
      "required": ["name", "price", "cost"]
    },
    "Product": {
      "title": "Product",
      "description": "A product sold by the salon",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the product" },
        "price": { "type": "number", "description": "Sales price" },
        "cost": { "type": "number", "description": "Cost price" },
        "quantity": { "type": "number", "description": "Stock quantity" }
      },
      "required": ["name", "price", "cost", "quantity"]
    },
    "Employee": {
      "title": "Employee",
      "description": "A barber or staff member",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name" },
        "role": { "type": "string", "description": "Job title/role" }
      },
      "required": ["name"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A customer of the salon",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["firstName", "lastName", "phone"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A scheduled service for a customer",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "serviceId": { "type": "string" },
        "employeeId": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled"] }
      },
      "required": ["customerName", "serviceId", "employeeId", "dateTime", "status"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A completed transaction",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "type": { "type": "string", "enum": ["service", "product"] },
              "price": { "type": "number" },
              "cost": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "totalCost": { "type": "number" },
        "employeeId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "dayId": { "type": "string", "description": "ID of the business day" }
      },
      "required": ["items", "totalAmount", "totalCost", "timestamp", "dayId"]
    },
    "BusinessDay": {
      "title": "BusinessDay",
      "description": "A tracking record for a specific business day",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "isClosed": { "type": "boolean" },
        "openingBalance": { "type": "number" },
        "closingBalance": { "type": "number" }
      },
      "required": ["date", "isClosed", "openingBalance"]
    }
  },
  "firestore": {
    "/services": { "schema": "Service", "description": "Collection of services" },
    "/products": { "schema": "Product", "description": "Collection of products" },
    "/employees": { "schema": "Employee", "description": "Collection of employees" },
    "/customers": { "schema": "Customer", "description": "Collection of customers" },
    "/appointments": { "schema": "Appointment", "description": "Collection of appointments" },
    "/sales": { "schema": "Sale", "description": "Collection of sales transactions" },
    "/days": { "schema": "BusinessDay", "description": "Collection of business days" }
  }
}
